# Normalise line endings
* text=auto eol=lf

# Unity YAML — use UnityYAMLMerge for conflict resolution
*.unity    merge=unityyamlmerge eol=lf
*.prefab   merge=unityyamlmerge eol=lf
*.asset    merge=unityyamlmerge eol=lf
*.meta     merge=unityyamlmerge eol=lf
*.asmdef   text eol=lf

# Source
*.cs       text eol=lf
*.shader   text eol=lf
*.hlsl     text eol=lf
*.cginc    text eol=lf

# Data / config
*.json     text eol=lf
*.md       text eol=lf
*.xml      text eol=lf
*.txt      text eol=lf

# Binary — do not diff or merge
*.png      binary
*.jpg      binary
*.jpeg     binary
*.gif      binary
*.psd      binary
*.tga      binary
*.tif      binary
*.tiff     binary
*.wav      binary
*.mp3      binary
*.ogg      binary
*.fbx      binary
*.dll      binary
*.so       binary
*.dylib    binary
